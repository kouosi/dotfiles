[include]
    path = ~/.local/share/.git.config
[alias]
    tree = log --graph --decorate --pretty=oneline --abbrev-commit --all
    lg = log --graph --pretty=format:'%C(yellow)%h%Creset %C(blue)%an%Creset %Cgreen(%ar)%Creset %s' --abbrev-commit
    branches = branch -a -v
    s = status -sb
    cleanup = branch --merged | grep -v '\\*\\|main\\|develop' | xargs -r git branch -d
[core]
    editor = nvim
[init]
    defaultBranch = main
[merge]
    conflictStyle = diff3
[http]
    postBuffer = 157286400
[commit]
    gpgsign = true
[gpg]
    program = gpg

#!/bin/bash
# version of sway-status without color printing

# CPU
get_cpu() {
	local cpu_info=$(grep 'cpu ' /proc/stat | awk '{usage=($2+$4)*100/($2+$4+$5); printf("%.1f%%", usage)}')
	echo " $cpu_info"
}

# Memory
get_mem() {
	echo "  $(free -h | awk '/Mem:/ {print $3 "/" $2}')"
}

# Uptime
get_uptime() {
	echo " $(awk '{d=int($1/86400); h=int(($1%86400)/3600); m=int(($1%3600)/60); if (d > 0) printf("%dd ", d); if (h > 0) printf("%dh ", h); if (m > 0 || (d == 0 && h == 0)) printf("%dm", m)}' /proc/uptime)"
}

# Battery
get_battery() {
	local battery_info="$(cat /sys/class/power_supply/BAT*/capacity)"
	local battery_status="$(cat /sys/class/power_supply/BAT*/status)"
	local battery
	if [ "$battery_status" = "Charging" ]; then
		if [ "$battery_info" -ge 80 ]; then
			notify-send -t 5000 -u normal "Battery Full" "Please remove charger" -i foot -w
		fi
		battery=" $battery_info%"
	elif [ "$battery_status" = "Discharging" ]; then
		local battery_icon
		if [ "$battery_info" -ge 80 ]; then
			battery_icon=" "
		elif [ "$battery_info" -ge 60 ]; then
			battery_icon=" "
		elif [ "$battery_info" -ge 40 ]; then
			battery_icon=" "
		elif [ "$battery_info" -ge 20 ]; then
			battery_icon=" "
		else
			notify-send -u critical -t 5000 "Battery Low ($battery_info%)" "Please plug to power supply" -i foot -w
			battery_icon=" "
		fi
		battery="$battery_icon $battery_info%"
	else
		battery="$battery_status $battery_info%"
	fi
	echo "$battery"
}

# Date and time
get_date() {
	echo " $(date '+%a %b-%d')"
}

get_time() {
	echo " $(date +'%H:%M')"
}

# Brightness
get_brightness() {
	local brt_info="$(($(brightnessctl get) * 100 / $(brightnessctl max)))"
	local brt_icon="$( [ "$brt_info" -ge 80 ] && echo ' ' || { [ "$brt_info" -ge 40 ] && echo ' ' || echo ''; } )"
	echo "$brt_icon $brt_info%"
}

# Wi-Fi
get_wifi() {
	local wifi_name=$(nmcli -t -f active,ssid dev wifi | grep '^yes' | cut -d':' -f2)
	local wifi
	local wifi_icon
	local wifi_strength
	if [ -z "$wifi_name" ]; then
		echo "Disconnected"
		return
	else
		local wifi_status="$(cat /sys/class/net/w*/operstate 2>/dev/null)"
		if [ $wifi_status = 'up' ] ; then
			wifi_strength="$(awk '/^\s*w/ { print int($3 * 100 / 70) }' /proc/net/wireless)"
			if [ "$wifi_strength" -ge 40 ]; then
				wifi_icon=" "
			else
				wifi_icon=" "
			fi
			wifi="$wifi_icon ($wifi_name) $wifi_strength%"
		else
			wifi_icon=" "
			wifi="$wifi_icon $wifi_strength%"
		fi
	fi
	echo "$wifi"
}

# Audio
get_volume() {
	local volume=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | awk '{print $2 * 100}')
	local mute_status=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -o "MUTED")
	local hp_status=$(amixer -c 0 get Headphone | grep -A 1 'Playback' | tail -n 1 | awk '{print $NF}')

	if [ "$mute_status" = "MUTED" ]; then
		echo " mute"
	else
		local vol_icon=$(echo "$hp_status" | awk '{print ($1 == "[on]") ? "" : " "}')
		echo "$vol_icon $volume%"
	fi
}

get_mic() {
	local volume=$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | awk '{print $2 * 100}')
	local mute_status=$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@ | grep -o "MUTED")

	if [ "$mute_status" = "MUTED" ]; then
		echo "󰍭"
	else
		echo "󰍬 $volume%"
	fi
}

# Display
while true; do
	printf " %s | %s | %s | %s | %s | %s \n" "$(get_time)" \
		"$(get_wifi)" "$(get_volume)" "$(get_brightness)" "$(get_battery)" "$(get_date)"
	sleep 0.25
done
